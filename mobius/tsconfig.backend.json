{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021"],
    "strict": true,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "."
  },
  "include": [
    "db.ts",
    "backend/repositories/**/*.ts",
    "backend/types/**/*.ts",
    "backend/routes/**/*.ts",
    "backend/middleware/**/*.ts",
    "backend/utils/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "public",
    "extension"
  ]
}

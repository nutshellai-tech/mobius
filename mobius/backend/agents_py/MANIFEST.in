# Source distribution manifest.
#
# Hatchling already picks up everything declared in
# [tool.hatch.build.targets.sdist] in pyproject.toml; this MANIFEST.in
# is here for tools that still consult it (older PyPI mirrors,
# setuptools fallbacks, etc.).

include README.md
include LICENSE
include CHANGELOG.md
include pyproject.toml

recursive-include src/aimax *.py
recursive-include src/aimax *.pyi
recursive-include src/tmux_agents *.py
recursive-include src/tmux_agents *.pyi

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store

{
  "name": "self-cognition",
  "display_name": "莫比乌斯的自我认知和迭代",
  "description": "沉淀自我改进、哥德尔智能体与递归迭代相关研究, 提炼对莫比乌斯可落地的启发与开发指示。",
  "version": "0.1.0",
  "icon": "favicon.svg",
  "schedule": [
    {
      "id": "self-cognition-arxiv-1700",
      "time": "17:00",
      "timezone": "UTC",
      "interval_minutes": 1440,
      "payload": {
        "action": "scan_arxiv",
        "scheduled_daily_scan": true,
        "auto_ai_read": true,
        "deep_read_backlog": true,
        "max_results": 100
      }
    },
    {
      "id": "self-cognition-products-1700",
      "time": "17:00",
      "timezone": "UTC",
      "interval_minutes": 1440,
      "payload": {
        "action": "scan_product_url",
        "scheduled_daily_scan": true,
        "auto_ai_read": true,
        "deep_read_backlog": true,
        "all_tracked": true,
        "discover": true
      }
    },
    {
      "id": "self-cognition-evolution-1700",
      "time": "17:00",
      "timezone": "UTC",
      "interval_minutes": 1440,
      "payload": {
        "action": "seed_evolution_from_git",
        "since": "auto",
        "limit": 80
      }
    }
  ],
  "project": {
    "sync": true,
    "default_hidden": true
  }
}

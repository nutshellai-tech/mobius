{
  "name": "mobius-system",
  "version": "1.9.0",
  "private": true,
  "description": "The world's first self-evolving open-source agent operating system, an AI workbench that can continuously self-iterate according to personalized needs.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test:access-control": "node --require tsx/cjs tests/access-control-policy.js",
    "test:user-isolation-v3": "node --require tsx/cjs tests/user-isolation-v3.js",
    "test:assistant-running-flag": "node --require tsx/cjs tests/assistant-running-flag.js",
    "test:assistant-tts-cache": "node --require tsx/cjs tests/assistant-tts-cache.js",
    "test:code-server-workspace": "node --require tsx/cjs tests/code-server-workspace.js",
    "test:native-file-menu": "node --require tsx/cjs tests/native-file-menu.js",
    "test:file-tree-menu-logic": "node --require tsx/cjs tests/file-tree-menu-logic.js",
    "test:session-transfer": "node --require tsx/cjs tests/session-transfer.js",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit",
    "start:tsx": "tsx server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "http-proxy": "^1.18.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.1.0",
    "pm2": "^7.0.1",
    "tsx": "^4.22.4",
    "uuid": "^9.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^18.19.130",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.9.3"
  }
}

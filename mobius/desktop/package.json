{
  "name": "mobius-desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Mobius Desktop — thin Electron shell (Fork B) with bundled aimux reverse-connect.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "fetch-python": "tsx scripts/fetch-python.ts",
    "dist:win": "npm run fetch-python && npm run build && electron-builder --win zip nsis"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}

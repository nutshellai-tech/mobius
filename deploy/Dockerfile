FROM node:18-bookworm

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
RUN sed -i 's@//.*deb.debian.org@//mirrors.aliyun.com@g; s@//.*security.debian.org@//mirrors.aliyun.com@g' /etc/apt/sources.list /etc/apt/sources.list.d/debian.sources 2>/dev/null || true
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        nano tmux proxychains-ng git curl ca-certificates tini \
        python3 make g++ procps less locales iproute2 psmisc openssh-server \
 && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# 代理网络配置（可选）—— 通过 build ARG 传入，禁止在此处硬编码账号密码
#
# 构建时传参示例：
#   docker build \
#     --build-arg PROXY_HOST=your.proxy.host \
#     --build-arg PROXY_PORT=12321 \
#     --build-arg PROXY_USER=your_username \
#     --build-arg PROXY_PASS=your_password \
#     -f deploy/DockerfileV0 -t imac-mobius:v0 .
# ---------------------------------------------------------------------------
ARG PROXY_HOST=""
ARG PROXY_PORT=""
ARG PROXY_USER=""
ARG PROXY_PASS=""
RUN if [ -n "$PROXY_HOST" ] && [ -n "$PROXY_PORT" ]; then \
      sed -i '$ d' /etc/proxychains4.conf; \
      sed -i '$ d' /etc/proxychains4.conf; \
      echo "http  ${PROXY_HOST}  ${PROXY_PORT} ${PROXY_USER} ${PROXY_PASS}" | tee -a /etc/proxychains4.conf; \
    fi
ENV fq=""
# 需要代理时将上一行改为: ENV fq="proxychains"

# ---------------------------------------------------------------------------
# code-server (official installer → /usr/bin/code-server)
# ---------------------------------------------------------------------------
RUN $fq wget -O /tmp/code-server-install.sh https://code-server.dev/install.sh
RUN $fq sh /tmp/code-server-install.sh
RUN rm -f /tmp/code-server-install.sh
RUN test -x /usr/bin/code-server

# ---------------------------------------------------------------------------
# Global npm CLIs: claude (PATH preflight) + codex (runtime).
# codex / codex_fqx wrappers are generated by the entrypoint at startup.
# ---------------------------------------------------------------------------
RUN $fq npm install -g @anthropic-ai/claude-code @openai/codex

COPY . /app_image
WORKDIR /app_image
# codex / claude 凭证种子: 放到不被 bind mount 遮盖的位置, entrypoint 首次启动时
# 若 host 挂载的 /root/.codex 或 /root/.claude 为空则从这里播种 (见 docker-entrypoint.sh)。
COPY ./deploy/codex /opt/codex-seed
COPY ./deploy/claude /opt/claude-seed

# 安装占位图片展示命令到全局 PATH, 供 agent 在容器内直接调用 display_images。
RUN PREFIX=/usr/local/bin bash ./scripts/install-dummy-bash-cmd-list.bash

RUN cd /app_image/mobius && $fq npm install
RUN cd /app_image/mobius/frontend && $fq npm install
RUN mkdir -p /app /data

# Git 全局用户配置 —— 通过 build ARG 传入，避免个人信息硬编码在镜像层中
ARG GIT_USER_EMAIL="dev@example.com"
ARG GIT_USER_NAME="Mobius Dev"
RUN git config --global user.email "${GIT_USER_EMAIL}" \
 && git config --global user.name  "${GIT_USER_NAME}"

CMD ["bash", "/app_image/docker-entrypoint.sh"]

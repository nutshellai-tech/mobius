# =============================================================================
# Mobius Local Development Environment Template (English)
#
# Usage:
#   cp .env.example .env
#   Then fill in real values according to the comments below
#
# 中文版注释模板：cp .env.example.zh .env
#
# Files:
#   - .env          Local secrets (gitignored, never commit)
#   - .env.example  This template (English)
#   - .env.example.zh  Chinese-commented template
#   - .env.default  Docker container defaults (lowest priority)
#
# Load priority (high → low):
#   External env vars > .env > .env.default
# =============================================================================


# =============================================================================
# [Required] API Keys
# =============================================================================

# ---------------------------------------------------------------------------
# Claude Code Agent Key (powers Agent sessions — the AI coding assistant in the
# right-hand chat panel)
#
# GLM-5.2 via Z.AI (GLM Coding plan, recommended):
#   ANTHROPIC_AUTH_TOKEN=<your Z.AI API Key>
#   ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
#
#   Get API Key: https://z.ai → Console → API Keys
#   Note: GLM Coding plan is required for the /api/anthropic endpoint
#
# Official Anthropic:
#   ANTHROPIC_AUTH_TOKEN=<sk-ant-... key>
#   ANTHROPIC_BASE_URL=https://api.anthropic.com
#
# Other proxies: replace ANTHROPIC_BASE_URL with your proxy URL
# ---------------------------------------------------------------------------
ANTHROPIC_AUTH_TOKEN=your-api-key-here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# ---------------------------------------------------------------------------
# Mobius built-in assistant & extension LLMs (chat UI + project-yongle /
# finance-news-wall, etc.) — OpenAI Chat Completions compatible format
#
# GLM-5.2 via Z.AI (recommended; same API key as above):
#   International: ASSISTANT_API_BASE=https://api.z.ai/api/paas/v4
#   China:         ASSISTANT_API_BASE=https://open.bigmodel.cn/api/paas/v4
#   ASSISTANT_MODEL=glm-5.2
#
#   Note: use /api/paas/v4 for general chat, NOT /api/coding/paas/v4 (Coding tools only)
#
# Other providers (pick one):
#   DeepSeek:  https://api.deepseek.com/v1          model: deepseek-chat
#   OpenAI:    https://api.openai.com/v1             model: gpt-4o-mini
#   Ollama:    http://localhost:11434/v1             model: qwen2.5:7b  (any string as key)
# ---------------------------------------------------------------------------
ASSISTANT_API_BASE=https://api.z.ai/api/paas/v4
ASSISTANT_API_KEY=your-api-key-here         # same as ANTHROPIC_AUTH_TOKEN
BEST_API_KEY=your-api-key-here              # same as above
ASSISTANT_MODEL=glm-5.2


# =============================================================================
# [Required] Security
# =============================================================================

# JWT signing secret for user authentication
# ⚠️  Must be a long random string — weak secrets allow token forgery
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-jwt-secret-here

# Bootstrap users created on first startup
# Format: id:password:role:display_name (multiple users separated by ;, role: admin|user)
# ⚠️  Use a strong password — do not use admin/admin
IMAC_BOOTSTRAP_USERS=admin:your-strong-password-here:admin:Admin


# =============================================================================
# [Optional] Doubao Speech (ASR / TTS — leave blank if not needed)
# =============================================================================

# Doubao ASR (speech recognition)
# Volcengine console: https://console.volcengine.com/speech/service/16
DOUBAO_ASR_APP_ID=
DOUBAO_ASR_ACCESS_TOKEN=
DOUBAO_ASR_SECRET_KEY=

# Doubao TTS (speech synthesis)
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=
DOUBAO_TTS_SECRET_KEY=


# =============================================================================
# Local paths (replace /Users/your-username with your actual $HOME)
# Quick check: echo $HOME
# =============================================================================

APP_DIR=/Users/your-username/PycharmProjects/mobius
MOBIUS_DATA_PATH=/Users/your-username/PycharmProjects/mobius/local_data
CORE_DATA_PATH=/Users/your-username/PycharmProjects/mobius/local_data/protected_data
MODEL_ACCESS_PATH=/Users/your-username/PycharmProjects/mobius/local_data/model-access.json
SHARED_SKILL_LIBRARY_DIR=/Users/your-username/PycharmProjects/mobius/local_data/shared-skill-library
SHARED_SKILL_BACKUP_DIR=/Users/your-username/PycharmProjects/mobius/local_data/shared-skill-library-backups

DB_PATH=/Users/your-username/PycharmProjects/mobius/local_data/mobius.db
WORKSPACE_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/workspace
HOME_WORKSPACE_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/workspace/home
LOCAL_WORKSPACE_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/workspace/_employees
TURNS_SUMMARY_DIR=/Users/your-username/PycharmProjects/mobius/local_data/turn-summaries
IMAC_DEBUG_ENV_FILE=/Users/your-username/PycharmProjects/mobius/.imac/debug-env.json

CODE_SERVER_CWD=/Users/your-username
CS_BIN=/usr/local/bin/code-server
CODE_SERVER_DATA_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/code_server
CS_DATA_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/code_server/cs-data
CS_EXT_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/code_server/cs-ext


# =============================================================================
# Ports (defaults usually work; change only if there is a port conflict)
# =============================================================================

MOBIUS_PORT=45614       # Backend API
VITE_PORT=45616         # Frontend dev server / web entry
CODE_SERVER_PORT=45617  # code-server (VS Code Web)


# =============================================================================
# Vite dev server (keep defaults for local development)
# =============================================================================

VITE_HOST=0.0.0.0
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
VITE_HMR_PROTOCOL=ws
VITE_HMR_CLIENT_PORT=45616

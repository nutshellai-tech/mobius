# =============================================================================
# Mobius 本地开发环境配置模板（中文版）
#
# 使用方式：
#   cp .env.example.zh .env
#   然后按注释说明填入真实值
#
# English template: cp .env.example .env
#
# 说明：
#   - .env            本地真实配置，已被 .gitignore 排除，不会提交到代码库
#   - .env.example    英文注释模板
#   - .env.example.zh 此模板文件（中文注释），可提交到代码库，供新成员参考
#   - .env.default    Docker 容器内默认值，优先级最低
#
# 加载优先级（高 → 低）：
#   外部环境变量 > .env > .env.default
# =============================================================================


# =============================================================================
# 【必填】API 密钥配置
# =============================================================================

# ---------------------------------------------------------------------------
# Claude Code Agent Key（驱动 Agent 会话，即右侧对话框里的 AI 编程助手）
#
# GLM-5.2 接入方式（GLM Coding 套餐，推荐）：
#   ANTHROPIC_AUTH_TOKEN=<你的 Z.AI API Key>
#   ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
#
#   API Key 获取：https://z.ai  → 控制台 → API Keys
#   注意：必须开通 GLM Coding 套餐才能使用 /api/anthropic 端点
#
# 官方 Anthropic 接入方式：
#   ANTHROPIC_AUTH_TOKEN=<sk-ant-... 格式的 Key>
#   ANTHROPIC_BASE_URL=https://api.anthropic.com
#
# 其他代理服务：将 ANTHROPIC_BASE_URL 替换为代理地址即可
# ---------------------------------------------------------------------------
ANTHROPIC_AUTH_TOKEN=your-api-key-here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# ---------------------------------------------------------------------------
# Mobius 内置助手 & 扩展 LLM（对话界面 + project-yongle / finance-news-wall 等扩展）
# 使用 OpenAI Chat Completions 兼容格式
#
# GLM-5.2 接入方式（推荐，与上面共用同一个 API Key）：
#   国际域名：ASSISTANT_API_BASE=https://api.z.ai/api/paas/v4
#   国内域名：ASSISTANT_API_BASE=https://open.bigmodel.cn/api/paas/v4
#   ASSISTANT_MODEL=glm-5.2
#
#   注意：通用聊天用 /api/paas/v4，不要用 /api/coding/paas/v4（那个仅限 Coding 工具）
#
# 其他服务商示例（选其一）：
#   DeepSeek：  https://api.deepseek.com/v1          模型：deepseek-chat
#   OpenAI：    https://api.openai.com/v1             模型：gpt-4o-mini
#   本地 Ollama：http://localhost:11434/v1            模型：qwen2.5:7b  Key 填任意字符串
# ---------------------------------------------------------------------------
ASSISTANT_API_BASE=https://api.z.ai/api/paas/v4
ASSISTANT_API_KEY=your-api-key-here         # 与 ANTHROPIC_AUTH_TOKEN 填同一个
BEST_API_KEY=your-api-key-here              # 同上
ASSISTANT_MODEL=glm-5.2


# =============================================================================
# 【必填】安全配置
# =============================================================================

# JWT Token 签名密钥，用于用户登录鉴权
# ⚠️  必须设置为足够随机的长字符串，否则任何人可伪造 token
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-jwt-secret-here

# 首次启动时自动创建的初始账号
# 格式：id:password:role:display_name（多个用 ; 分隔，role 可选 admin|user）
# ⚠️  请使用强密码，不要用 admin/admin
IMAC_BOOTSTRAP_USERS=admin:your-strong-password-here:admin:管理员


# =============================================================================
# 【按需填写】豆包语音（ASR 语音识别 / TTS 语音合成，不需要可留空）
# =============================================================================

# 豆包 ASR（语音识别）
# 在火山引擎控制台获取：https://console.volcengine.com/speech/service/16
DOUBAO_ASR_APP_ID=
DOUBAO_ASR_ACCESS_TOKEN=
DOUBAO_ASR_SECRET_KEY=

# 豆包 TTS（语音合成）
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=
DOUBAO_TTS_SECRET_KEY=


# =============================================================================
# 本地路径配置（将 /Users/your-username 替换为你的实际 $HOME 路径）
# 快速获取：echo $HOME
# =============================================================================

APP_DIR=/Users/your-username/PycharmProjects/mobius
MOBIUS_DATA_PATH=/Users/your-username/PycharmProjects/mobius/local_data
CORE_DATA_PATH=/Users/your-username/PycharmProjects/mobius/local_data/protected_data
MODEL_ACCESS_PATH=/Users/your-username/PycharmProjects/mobius/local_data/model-access.json
SHARED_SKILL_LIBRARY_DIR=/Users/your-username/PycharmProjects/mobius/local_data/shared-skill-library
SHARED_SKILL_BACKUP_DIR=/Users/your-username/PycharmProjects/mobius/local_data/shared-skill-library-backups

DB_PATH=/Users/your-username/PycharmProjects/mobius/local_data/mobius.db
WORKSPACE_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/workspace
HOME_WORKSPACE_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/workspace/home
LOCAL_WORKSPACE_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/workspace/_employees
TURNS_SUMMARY_DIR=/Users/your-username/PycharmProjects/mobius/local_data/turn-summaries
IMAC_DEBUG_ENV_FILE=/Users/your-username/PycharmProjects/mobius/.imac/debug-env.json

CODE_SERVER_CWD=/Users/your-username
CS_BIN=/usr/local/bin/code-server
CODE_SERVER_DATA_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/code_server
CS_DATA_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/code_server/cs-data
CS_EXT_ROOT=/Users/your-username/PycharmProjects/mobius/local_data/code_server/cs-ext


# =============================================================================
# 端口配置（默认值通常无需修改，端口冲突时调整）
# =============================================================================

MOBIUS_PORT=45614       # 后端 API
VITE_PORT=45616         # 前端 Dev Server / Web 入口
CODE_SERVER_PORT=45617  # code-server (VSCode Web)


# =============================================================================
# Vite 开发服务器（本地开发保持默认即可）
# =============================================================================

VITE_HOST=0.0.0.0
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
VITE_HMR_PROTOCOL=ws
VITE_HMR_CLIENT_PORT=45616

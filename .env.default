# IMAC default runtime configuration.
#
# debug.py loads configuration in this exact priority:
# 1. External environment
# 2. .env in the current working directory
# 3. .env.default in the current working directory
#
# Keep every value in this file non-empty so default behavior is explicit.

# ---------------------------------------------------------------------------
# Core paths
# ---------------------------------------------------------------------------

APP_DIR=/app
MOBIUS_DATA_PATH=/data
CORE_DATA_PATH=/data/protected_data
MODEL_ACCESS_PATH=/data/model-access.json
SHARED_SKILL_LIBRARY_DIR=/data/shared-skill-library
SHARED_SKILL_BACKUP_DIR=/data/shared-skill-library-backups

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------

MOBIUS_PORT=33314
VITE_PORT=33316
CODE_SERVER_PORT=33317

# ---------------------------------------------------------------------------
# Vite dev server
# ---------------------------------------------------------------------------

VITE_HOST=0.0.0.0
VITE_ALLOWED_HOSTS=.agent-matrix.com
VITE_HMR_PROTOCOL=wss
VITE_HMR_CLIENT_PORT=443


# ---------------------------------------------------------------------------
# Backend app config
# ---------------------------------------------------------------------------

DB_PATH=/data/mobuis.db

# JWT_SECRET: 用于签发 / 验证用户 JWT Token，必须设置为足够随机的长字符串。
# ⚠️  生产环境若未设置，后端将拒绝启动（见 mobius/backend/config.js）。
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-please-generate-a-random-secret

ENABLE_PASSWORD_LOGIN=true
WORKSPACE_ROOT=/data/workspace
HOME_WORKSPACE_ROOT=/data/workspace/home
LOCAL_WORKSPACE_ROOT=/data/workspace/_employees
TURNS_SUMMARY_DIR=/data/turn-summaries

# IMAC_BOOTSTRAP_USERS: 首次启动自动创建的初始账号，格式 "id:password:role:display_name"，
# 多个用户用 ";" 分隔，role 可选 admin|user。
# ⚠️  请修改为强密码，避免使用 admin/admin 等弱密码。
# 示例：admin:请替换为强密码:admin:管理员
# 生产部署前务必修改！
IMAC_BOOTSTRAP_USERS=admin:change-me-strong-password:admin:管理员

# ---------------------------------------------------------------------------
# Assistant API（Mobius 内置助手对话模型，与 Claude Code agent 独立）
#
# ASSISTANT_API_BASE: 兼容 OpenAI 格式的 API 地址，必填。
#   - 内网自建服务示例：http://<host>:<port>/v1
#   - 公有云 OpenAI 兼容接口：https://api.openai.com/v1
# ASSISTANT_API_KEY: 对应 API 的鉴权 Key，必填。
# BEST_API_KEY:      用于优选模型调用的 Key（可与 ASSISTANT_API_KEY 相同），必填。
# ---------------------------------------------------------------------------

ASSISTANT_API_BASE=replace-me-assistant-api-base-url
ASSISTANT_API_KEY=replace-me-assistant-api-key
BEST_API_KEY=replace-me-best-api-key
ASSISTANT_MODEL=gpt-5.5

# ---------------------------------------------------------------------------
# Assistant voice: Doubao ASR / TTS
# ---------------------------------------------------------------------------

DOUBAO_ASR_APP_ID=replace-me-doubao-asr-app-id
DOUBAO_ASR_ACCESS_TOKEN=replace-me-doubao-asr-access-token
DOUBAO_ASR_SECRET_KEY=replace-me-doubao-asr-secret-key
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
DOUBAO_TTS_APP_ID=replace-me-doubao-tts-app-id
DOUBAO_TTS_ACCESS_TOKEN=replace-me-doubao-tts-access-token
DOUBAO_TTS_SECRET_KEY=replace-me-doubao-tts-secret-key
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_TTS_VOICE_TYPE=zh_female_vv_uranus_bigtts

# ---------------------------------------------------------------------------
# Agent/runtime integrations
# ---------------------------------------------------------------------------

IMAC_SKILLS_PROXY=disabled
IMAC_SKILLS_NO_PROXY=registry.npmmirror.com,registry.npmjs.org,npmmirror.com,localhost,127.0.0.1
IMAC_TMUX_AGENT_INACTIVE_MS=10800000
IMAC_TMUX_AGENT_CLEANUP_INTERVAL_MS=1800000
IMAC_TMUX_AGENT_CLEANUP_FIRST_DELAY_MS=60000

# ---------------------------------------------------------------------------
# code-server
# ---------------------------------------------------------------------------

CODE_SERVER_CWD=/root
CS_BIN=/usr/bin/code-server
CODE_SERVER_DATA_ROOT=/data/code_server
CS_DATA_ROOT=/data/code_server/cs-data
CS_EXT_ROOT=/data/code_server/cs-ext
CS_PORT_BASE=45700
CS_POOL_MAX=32
CS_IDLE_TIMEOUT_MIN=60
CS_MAX_PER_USER=4
CS_MAX_TOTAL=16
CS_READY_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Claude Code agent (debug.py writes these into $HOME/.claude/settings.api.json)
#
# ANTHROPIC_AUTH_TOKEN: Claude Code 的鉴权 Token，必填。
#   - 官方 Anthropic：在 https://console.anthropic.com 获取，格式 sk-ant-...
#   - 自定义代理：在代理服务商处获取对应 token
#
# ANTHROPIC_BASE_URL: Claude Code 请求的 API Base URL，必填。
#   - 官方端点：https://api.anthropic.com
#   - 使用代理时：替换为代理地址（如 https://your-proxy.example.com/claude）
# ---------------------------------------------------------------------------

ANTHROPIC_AUTH_TOKEN=replace-me-anthropic-auth-token
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------------------------------------------------------------------------
# Deployment / compose
# ---------------------------------------------------------------------------

NPM_REGISTRY=https://registry.npmjs.org/
